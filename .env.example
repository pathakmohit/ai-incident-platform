# Database (Amazon RDS)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=incidents_db

# Backend
NODE_ENV=production
PORT=5000
